# Server
PORT=3000

# Owner authentication
# Generate a unique high-entropy secret of at least 32 characters.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# PostgreSQL
POSTGRES_DB=koharu
POSTGRES_USER=koharu
POSTGRES_PASSWORD=koharu
DATABASE_URL=postgresql://koharu:koharu@localhost:5432/koharu

# Telegram
# Create a bot with @BotFather, add it as an administrator of one public channel,
# and replace these placeholders locally. Never commit the real token.
TELEGRAM_BOT_TOKEN=replace-with-bot-token
TELEGRAM_CHANNEL_ID=-1001234567890
