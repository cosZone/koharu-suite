# Server
PORT=3000

# Owner authentication
# Generate a unique high-entropy secret of at least 32 characters.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# PostgreSQL
POSTGRES_DB=koharu
POSTGRES_USER=koharu
POSTGRES_PASSWORD=koharu
DATABASE_URL=postgresql://koharu:koharu@localhost:5432/koharu

# Telegram
# Create one bot with @BotFather and make it an administrator of every public
# channel you configure. Never commit the real token.
TELEGRAM_BOT_TOKEN=replace-with-bot-token
TELEGRAM_WORKER_CONCURRENCY=4

# Optional one-time compatibility bootstrap. Prefer `kodama channel add`.
# It is ignored once the database allowlist is non-empty.
TELEGRAM_CHANNEL_ID=
